# ─── Banco de Dados ───
DATABASE_URL="postgresql://licitasaas:SUA_SENHA_AQUI@localhost:5432/licitasaas?schema=public"
POSTGRES_PASSWORD="SUA_SENHA_AQUI"

# ─── Segurança ───
JWT_SECRET="gere-uma-chave-aleatoria-com-openssl-rand-hex-64"

# Chave AES-256 para criptografia de credenciais de portais (64 chars hex = 32 bytes)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=""

# URL do frontend (usado para CORS em produção)
FRONTEND_URL="https://seu-dominio.com"

# ─── Google Gemini (IA) ───
GEMINI_API_KEY="AIzaSy..."

# ─── Storage (LOCAL para dev, SUPABASE para produção) ───
# Opções: LOCAL | SUPABASE | S3
STORAGE_TYPE="LOCAL"

# Supabase Storage (Necessário se STORAGE_TYPE="SUPABASE")
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_KEY="sua-anon-key-ou-service-role-key"
SUPABASE_BUCKET="documents"

# ─── Porta ───
PORT=3001

# ─── Arquitetura de Processos ───
# 'all' = API + Workers juntos (legado/dev), 'api' = só HTTP, 'worker' = só pollers
PROCESS_ROLE="all"
# Porta do health check do Worker (apenas quando PROCESS_ROLE=worker)
WORKER_HEALTH_PORT=3002

# ─── Frontend (usado durante o build) ───
# Deixe vazio se frontend e backend estão no mesmo domínio
VITE_API_URL=""

# ─── Notificações Radar ───
TELEGRAM_BOT_TOKEN="sua_chave_aqui"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
