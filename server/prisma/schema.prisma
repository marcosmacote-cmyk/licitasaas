generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                     String                  @id @default(uuid())
  rootCnpj               String                  @unique
  razaoSocial            String
  createdAt              DateTime                @default(now())
  biddingProcesses       BiddingProcess[]
  companies              CompanyProfile[]
  documents              Document[]
  users                  User[]
  globalConfig           GlobalConfig?
  pncpSearches           PncpSavedSearch[]
  proposals              PriceProposal[]
  technicalCertificates  TechnicalCertificate[]
  chatMonitorConfig      ChatMonitorConfig?
  chatMonitorLogs        ChatMonitorLog[]
  opportunityScannerLogs OpportunityScannerLog[]
  pncpFavoriteLists      PncpFavoriteList[]
  pncpFavoriteItems      PncpFavoriteItem[]
  insightHistories       CompanyInsightHistory[]
  backgroundJobs         BackgroundJob[]
  auditLogs              AuditLog[]
}

model User {
  id                        String  @id @default(uuid())
  tenantId                  String
  name                      String
  email                     String  @unique
  passwordHash              String
  role                      String  @default("ANALISTA") // ADMIN, GERENTE, ANALISTA, VISUALIZADOR
  isActive                  Boolean @default(true)
  opportunityScannerEnabled Boolean @default(true)

  totpSecret                String?
  is2faEnabled              Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sessions UserSession[]
  auditLogs AuditLog[]
}

model CompanyProfile {
  id                          String  @id @default(uuid())
  tenantId                    String
  isHeadquarters              Boolean @default(false)
  cnpj                        String  @unique
  razaoSocial                 String
  qualification               String? // New field for company and representative qualification
  technicalQualification      String? // Technical responsible (CREA/CAU) qualification
  contactName                 String?
  contactCpf                  String? // CPF do Sócio Administrador / Representante Legal
  contactEmail                String?
  contactPhone                String?
  address                     String? // Endereço Completo
  city                        String? // Cidade Sede
  state                       String? // UF (sigla)
  defaultProposalHeader       String? // Base64 image
  defaultProposalFooter       String? // Base64 image
  defaultProposalHeaderHeight Int?    @default(80)
  defaultProposalFooterHeight Int?    @default(60)
  defaultLetterContent        String? // Default letter template content
  defaultSignatureConfig      String? // JSON: { sigLegal, sigTech, sigCompany, bankData, signatureMode, validityDays }

  // ── AI Learning & Company Profile ──
  strengths                Json? // Arra de strings (pontos fortes)
  knownWeaknesses          Json? // Array de strings (fragilidades)
  technicalAssets          Json? // JSON com certificados, atestados, artCatRrt
  documentaryAssets        Json? // Backup dos ultimos documentos parseados
  readinessFlags           Json? // Flags de prontidao
  registrations            Json? // Conselhos de classe etc
  responsibleProfessionals Json? // RTs e profissionais
  historicalPerformance    Json? // Opcional, summary de participações
  biddingProcesses         BiddingProcess[]
  credentials              CompanyCredential[]
  pncpSearches             PncpSavedSearch[]
  proposals                PriceProposal[]
  tenant                   Tenant                  @relation(fields: [tenantId], references: [id])
  documents                Document[]
  technicalCertificates    TechnicalCertificate[]
  insightHistories         CompanyInsightHistory[]
}

model CompanyInsightHistory {
  id              String   @id @default(uuid())
  tenantId        String
  companyId       String
  insightId       String   @unique
  category        String
  description     String
  frequency       Int      @default(1)
  evidence        Json
  suggestedAction String?
  createdAt       DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([tenantId])
}

model BiddingProcess {
  id               String           @id @default(uuid())
  tenantId         String
  companyProfileId String?
  title            String
  summary          String?
  portal           String
  modality         String
  status           String           @default("Captado")
  substage         String? // Subfase operacional interna
  risk             String?
  estimatedValue   Float            @default(0.0)
  sessionDate      DateTime
  link             String?
  pncpLink         String? // URL original do PNCP (ex: "https://pncp.gov.br/app/editais/CNPJ/ANO/SEQ") — preservado para monitoramento
  uasg             String? // UASG do órgão (ex: "943001") — para ComprasNet
  modalityCode     String? // Código da modalidade (ex: "5" = Pregão Eletrônico)
  processNumber    String? // Número do processo (ex: "91398")
  processYear      String? // Ano do processo (ex: "2025")
  isMonitored      Boolean          @default(false)
  observations     String?          @default("[]")
  reminderDate     DateTime?
  reminderStatus   String?          @default("pending")
  reminderType     String?          @default("once")
  reminderDays     String?          @default("[]")
  aiAnalysis       AiAnalysis?
  proposals        PriceProposal[]
  chunks           DocumentChunk[]
  chatMonitorLogs  ChatMonitorLog[]
  company          CompanyProfile?  @relation(fields: [companyProfileId], references: [id])
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
}

model AiAnalysis {
  id                        String         @id @default(uuid())
  biddingProcessId          String         @unique
  requiredDocuments         String
  biddingItems              String?
  pricingConsiderations     String?
  irregularitiesFlags       String
  fullSummary               String?
  deadlines                 String?
  penalties                 String?
  qualificationRequirements String?
  chatHistory               String?        @default("[]")
  sourceFileNames           String?        @default("[]")
  schemaV2                  Json? // AnalysisSchemaV1 structured output from V2 pipeline
  promptVersion             String? // Version of prompts used (e.g. "v2.0.0")
  modelUsed                 String? // AI model used (e.g. "gemini-2.5-flash")
  pipelineDurationS         Float? // Total pipeline duration in seconds
  overallConfidence         String? // baixa | media | alta
  requiresHumanAudit        Boolean @default(false)
  analyzedAt                DateTime       @default(now())
  biddingProcess            BiddingProcess @relation(fields: [biddingProcessId], references: [id], onDelete: Cascade)
}

model Document {
  id               String          @id @default(uuid())
  tenantId         String
  companyProfileId String?
  docType          String
  fileUrl          String
  uploadDate       DateTime        @default(now())
  expirationDate   DateTime
  status           String          @default("Válido")
  autoRenew        Boolean         @default(false)
  docGroup         String          @default("Outros")
  issuerLink       String?
  fileName         String          @default("Documento")
  fileContent      Bytes?
  alertDays        Int?            @default(15)
  company          CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
}

model GlobalConfig {
  id       String @id @default(uuid())
  tenantId String @unique
  config   String @default("{}") // JSON string for various settings
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model CompanyCredential {
  id               String         @id @default(uuid())
  companyProfileId String
  platform         String
  url              String?
  login            String
  password         String
  notes            String?
  createdAt        DateTime       @default(now())
  company          CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model PncpSavedSearch {
  id               String   @id @default(uuid())
  tenantId         String
  companyProfileId String?
  name             String
  keywords         String?
  status           String?  @default("aberta")
  states           String? // Stored as JSON string
  regions          String? // Stored as JSON string
  listName         String   @default("Pesquisas Gerais") // Group into named lists
  createdAt        DateTime @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model OpportunityScannerLog {
  id         String  @id @default(uuid())
  tenantId   String
  pncpId     String // ID do edital no PNCP (numeroControlePNCP)
  searchId   String // ID da pesquisa salva que detectou. AGORA OBRIGATÓRIO!
  searchName String? // Nome da pesquisa (snapshot para exibição)

  // ── Dados completos do edital (para aba "Encontradas") ──
  titulo                   String?
  objeto                   String? @db.Text
  orgaoNome                String?
  orgaoCnpj                String? // CNPJ do órgão — necessário para consultar itens no Gov.br
  anoCompra                String? // Ano da compra — necessário para consultar itens
  sequencialCompra         String? // Sequencial — necessário para consultar itens
  uf                       String?
  municipio                String?
  valorEstimado            Float?
  dataEncerramentoProposta String?
  modalidadeNome           String?
  linkSistema              String?

  isViewed  Boolean  @default(false) // Marcar como "visto" (lido/não lido)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Deduplicação agora é a nível de Pesquisa! Se um edital bater em duas pesquisas diferentes,
  // ele deve aparecer nas duas caixas de entrada (sem conflitar).
  @@unique([tenantId, searchId, pncpId])
  @@index([tenantId, createdAt])
}

// ── Favoritos PNCP (persistidos no banco — sincroniza entre dispositivos) ──
model PncpFavoriteList {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  items  PncpFavoriteItem[]
  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model PncpFavoriteItem {
  id        String   @id @default(uuid())
  tenantId  String
  listId    String
  pncpId    String // ID único do edital no PNCP
  data      Json // Dados completos do item (titulo, orgao, objeto, etc.)
  createdAt DateTime @default(now())

  list   PncpFavoriteList @relation(fields: [listId], references: [id], onDelete: Cascade)
  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, listId, pncpId])
  @@index([tenantId])
}

model PriceProposal {
  id                String   @id @default(uuid())
  tenantId          String
  biddingProcessId  String
  companyProfileId  String
  version           Int      @default(1)
  status            String   @default("Rascunho")
  objectType        String   @default("AQUISICAO") // AQUISICAO, ENGENHARIA, TERCEIRIZACAO
  bdiPercentage     Float    @default(0)
  taxPercentage     Float    @default(0)
  socialCharges     Float    @default(0)
  totalValue        Float    @default(0)
  letterContent     String?
  companyLogo       String?
  headerImage       String?
  headerImageHeight Int      @default(150)
  footerImage       String?
  footerImageHeight Int      @default(100)
  signatureMode     String   @default("LEGAL") // LEGAL, TECH, BOTH
  signatureCity     String?
  notes             String?
  validityDays      Int      @default(60)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // ── Cenário Proposta Ajustada ──
  adjustedBdi           Float?
  adjustedDiscount      Float?
  adjustedTotalValue    Float?
  adjustedLetterContent String?

  items          ProposalItem[]
  biddingProcess BiddingProcess @relation(fields: [biddingProcessId], references: [id], onDelete: Cascade)
  company        CompanyProfile @relation(fields: [companyProfileId], references: [id])
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
}

model ProposalItem {
  id                 String  @id @default(uuid())
  proposalId         String
  itemNumber         String
  description        String
  unit               String  @default("UN")
  quantity           Float   @default(0)
  multiplier         Float   @default(1)
  multiplierLabel    String?
  unitCost           Float   @default(0)
  unitPrice          Float   @default(0)
  totalPrice         Float   @default(0)
  referencePrice     Float?
  brand              String?
  model              String?
  discountPercentage Float?  @default(0) // Individual discount per item
  costComposition    String?
  sortOrder          Int     @default(0)

  // ── Cenário Proposta Ajustada ──
  adjustedUnitCost     Float? // null = herda unitCost
  adjustedUnitPrice    Float?
  adjustedTotalPrice   Float?
  adjustedItemDiscount Float? @default(0)

  proposal PriceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model DocumentChunk {
  id               String   @id @default(uuid())
  biddingProcessId String
  content          String   @db.Text
  metadata         Json?
  embedding        Json?
  createdAt        DateTime @default(now())

  biddingProcess BiddingProcess @relation(fields: [biddingProcessId], references: [id], onDelete: Cascade)

  @@index([biddingProcessId])
}

model TechnicalCertificate {
  id                   String    @id @default(uuid())
  tenantId             String
  companyProfileId     String?
  title                String
  type                 String    @default("Atestado") // Atestado, CAT, Acervo
  fileUrl              String
  fileName             String
  issuer               String? // Contratante
  issueDate            DateTime?
  object               String?   @db.Text
  executingCompany     String? // Empresa contratada
  technicalResponsible String? // RT do atestado
  category             String? // Categoria do acervo (ex: Obras, Locação)
  extractedData        Json? // AI extraction meta
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  experiences CertificateExperience[]
  tenant      Tenant                  @relation(fields: [tenantId], references: [id])
  company     CompanyProfile?         @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model CertificateExperience {
  id                     String  @id @default(uuid())
  technicalCertificateId String
  description            String  @db.Text // Descrição do serviço/item
  quantity               Float?
  unit                   String?
  category               String? // Categoria técnica (ex: Obras, TI)

  certificate TechnicalCertificate @relation(fields: [technicalCertificateId], references: [id], onDelete: Cascade)
}

model ChatMonitorConfig {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  keywords               String?  @default("suspensa,reaberta,vencedora")
  customKeywords         String?  @default("[]")
  enabledCategories      String?  @default("[\"convocacao\",\"vencedor\",\"encerramento\",\"prazo_docs\",\"suspensao\",\"reabertura\",\"impugnacao\",\"inabilitacao\",\"negociacao\"]")
  categoryCustomKeywords String?  @default("{}")
  phoneNumber            String?
  telegramChatId         String?
  notificationEmail      String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ChatMonitorLog {
  id               String         @id @default(uuid())
  tenantId         String
  biddingProcessId String
  messageId        String? // UUID da mensagem (chaveMensagemNaOrigem)
  fingerprintHash  String?        @unique // Hash sha256 para deduplicação robusta (Fase 3)
  content          String         @db.Text
  detectedKeyword  String?
  sentTo           String? // Phone or Telegram ID
  status           String         @default("SENT") // SENT, FAILED, PENDING_NOTIFICATION, SKIPPED, NO_CHANNEL
  authorType       String? // "sistema", "pregoeiro", "fornecedor"
  authorCnpj       String? // CNPJ do remetente
  eventCategory    String? // Código de categoria ("8"=convocação, "9"=comunicado, etc.)
  itemRef          String? // Item da disputa ("2", "3", etc.)
  captureSource    String?        @default("pncp-status") // "comprasnet-xhr" ou "pncp-status"
  messageTimestamp String? // Data/hora original da mensagem na plataforma (ex: "24/03/2026 16:48:34")
  isRead           Boolean        @default(false)
  isImportant      Boolean        @default(false)
  isArchived       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  biddingProcess   BiddingProcess @relation(fields: [biddingProcessId], references: [id], onDelete: Cascade)
}

// ── Rastreamento de Consumo de IA por Tenant ──
model AiUsageLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String? // Null for system-initiated calls (scanner, monitoring)
  operation    String // e.g. "analysis", "chat", "proposal_letter", "declaration", "oracle", "dossier"
  model        String // e.g. "gemini-2.5-flash", "gemini-2.5-pro"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  durationMs   Int      @default(0)
  success      Boolean  @default(true)
  errorMessage String?
  metadata     Json? // Additional context (e.g. biddingProcessId, prompt version)
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([operation])
}

// ── Telemetria de Pipeline de Análise IA ──
model AiAnalysisTelemetry {
  id              String   @id @default(uuid())
  tenantId        String
  processId       String?  // biddingProcessId if available
  timestamp       DateTime @default(now())
  
  // Input metrics
  numPdfs         Int      @default(0)
  totalPages      Int      @default(0)
  totalChars      Int      @default(0)
  hasScannedPdf   Boolean  @default(false)
  portal          String?
  modalidade      String?
  objeto          String?  // Truncated to 200 chars
  
  // Extraction metrics
  model           String   // 'gemini-2.5-flash', 'gpt-4o-mini', 'gpt-4o'
  promptVersion   String
  extractionTimeMs Int     @default(0)
  totalTimeMs     Int      @default(0)
  parseRepairs    Int      @default(0)
  fallbackUsed    Boolean  @default(false)
  categoryGapRecovery Boolean @default(false)
  
  // Output metrics
  totalRequirements Int    @default(0)
  categoryCounts  Json?    // { "HJ": 5, "RFT": 11, ... }
  totalEvidences  Int      @default(0)
  totalRisks      Int      @default(0)
  qualityScore    Float?
  confidenceScore Float?
  
  // SchemaEnforcer metrics
  enforcerCorrections Int  @default(0)
  safetyNetsTriggered Json? // ["RFT_CND", "QEF_BALANCO", ...]
  
  // Result
  status          String   @default("success") // success | partial | error
  errorMessage    String?
  
  @@index([tenantId, timestamp])
  @@index([status])
  @@index([qualityScore])
}

model BackgroundJob {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  type        String   // edital_analysis | oracle | proposal_populate | petition
  status      String   @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  progress    Int      @default(0) // 0-100
  progressMsg String?  // "Etapa 2/3 — Normalização"
  input       Json     // Payload original (fileNames, processId, etc.)
  result      Json?    // Resultado quando COMPLETED
  error       String?  // Mensagem de erro quando FAILED
  targetId    String?  // biddingProcessId — para vincular ao recurso
  targetTitle String?  // "Pregão 014/2026 - Macau" — para notificação legível
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([status, createdAt])
}

// ── SPRINT 5: Enterprise (Auth Avançada e Audit Log) ──

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  device    String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  action      String   // ex: LOGIN, UPDATE_PROCESS, DELETE_USER
  entityType  String   // ex: BiddingProcess, User
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
}

// ═══════════════════════════════════════════════════════════
// ── PNCP Aggregator: Base local de contratações públicas ──
// Sync a cada 15min via CRON. Elimina dependência real-time do Gov.br.
// ═══════════════════════════════════════════════════════════

model PncpContratacao {
  id                 String   @id @default(uuid())
  numeroControle     String   @unique // "CNPJ-X-SEQ/ANO" (numeroControlePNCP)
  cnpjOrgao          String   // CNPJ do órgão (14 dígitos)
  anoCompra          Int      // Ano da compra
  sequencialCompra   Int      // Sequencial da compra

  // Dados do órgão
  orgaoNome          String?
  unidadeNome        String?
  uf                 String?  // Sigla UF (2 chars)
  municipio          String?
  esfera             String?  // F=Federal, E=Estadual, M=Municipal

  // Dados da contratação
  objeto             String?  @db.Text
  modalidade         String?  // Nome da modalidade
  modalidadeCodigo   String?  // Código numérico
  situacao           String?  // "Aberta", "Encerrada", etc
  valorEstimado      Float?
  valorHomologado    Float?
  srp                Boolean  @default(false)
  modoDisputa        String?
  numeroCompra       String?  // Número da compra no órgão

  // Datas
  dataPublicacao     DateTime?
  dataAbertura       DateTime?
  dataEncerramento   DateTime?
  dataInclusao       DateTime?

  // Links
  linkSistema        String?  // URL do edital no PNCP
  linkOrigem         String?  // URL do sistema de origem

  // Full-Text Search vector (maintained by PostgreSQL trigger)
  searchVector       Unsupported("tsvector")?

  // Controle de sync
  syncedAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relacionamentos
  itens              PncpItem[]

  @@index([uf])
  @@index([situacao])
  @@index([modalidade])
  @@index([dataPublicacao])
  @@index([valorEstimado])
  @@index([cnpjOrgao, anoCompra, sequencialCompra])
  @@index([uf, situacao])
  @@index([dataEncerramento])
}

model PncpItem {
  id               String  @id @default(uuid())
  contratacaoId    String
  numeroItem       Int
  descricao        String? @db.Text
  quantidade       Float?
  unidadeMedida    String?
  valorUnitario    Float?
  valorTotal       Float?
  situacao         String? // Situação do item
  tipoBeneficio    String? // ME/EPP, etc

  contratacao PncpContratacao @relation(fields: [contratacaoId], references: [id], onDelete: Cascade)

  @@unique([contratacaoId, numeroItem])
  @@index([contratacaoId])
}

// Estado do sync para o aggregator
model PncpSyncState {
  id              String   @id @default("singleton")
  lastSyncAt      DateTime @default(now())
  lastFullSyncAt  DateTime @default(now())
  totalSynced     Int      @default(0)
  lastError       String?
  isRunning       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// ── Módulo de Obras e Serviços de Engenharia ──
// ═══════════════════════════════════════════════════════════

model EngineeringDatabase {
  id          String   @id @default(uuid())
  tenantId    String?  // Null if official global database (SINAPI, SEINFRA, ORSE)
  name        String   // "SINAPI", "SEINFRA", "Minha Construtora"
  uf          String?  // "CE", "SP", etc
  version     String?  // "2026-04", "028.1"
  type        String   @default("OFICIAL") // OFICIAL, PROPRIA
  
  items         EngineeringItem[]
  compositions  EngineeringComposition[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([type])
}

model EngineeringItem {
  id              String   @id @default(uuid())
  databaseId      String
  
  code            String   // "00001", "I1234"
  description     String   @db.Text
  unit            String   // "KG", "H", "M3"
  price           Float    // Unit price without BDI
  type            String   @default("MATERIAL") // MATERIAL, MAO_DE_OBRA, EQUIPAMENTO, SERVICO
  
  database        EngineeringDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  compositionRefs EngineeringCompositionItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([databaseId, code])
}

model EngineeringComposition {
  id              String   @id @default(uuid())
  databaseId      String
  
  code            String   // "C0010"
  description     String   @db.Text
  unit            String   // "M2", "M3", "UN"
  totalPrice      Float    // Calculated total price without BDI
  
  database        EngineeringDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  items           EngineeringCompositionItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([databaseId, code])
}

model EngineeringCompositionItem {
  id              String   @id @default(uuid())
  compositionId   String
  
  // A composition item can be a basic item (material/labor) OR another composition (auxiliary)
  itemId          String?
  auxiliaryCompositionId String? 
  
  coefficient     Float    // Quantity of the item required for 1 unit of the composition
  price           Float    // Snapshot of the price at the time of creation (price * coefficient)

  composition     EngineeringComposition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  item            EngineeringItem? @relation(fields: [itemId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([compositionId])
  @@index([itemId])
}
