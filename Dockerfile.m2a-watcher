FROM python:3.11-slim

WORKDIR /app

# Copia apenas os arquivos da subpasta m2a-watcher
# O contexto de build é a raiz do repositório
COPY m2a-watcher/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY m2a-watcher/ .

# Logs em tempo real
ENV PYTHONUNBUFFERED=1

CMD ["python", "main.py"]
